# mrrawbot environment — OPTIONAL.
# Provider config (Claude/Codex CLI paths, Ollama Cloud API key) is normally set
# in the app under Settings → Providers and stored encrypted in the local SQLite
# database. This file is only a fallback/override for power users.
# Values here are MERGED with your shell environment; real shell/system
# variables take precedence over what's written in this file.

# ---- Server ----
MRRAWBOT_PORT=4000
# MRRAWBOT_DB=./data/mrrawbot.db

# ---- Repo discovery (colon- or comma-separated roots; ~ is expanded) ----
# Defaults to your whole home directory (depth-limited, heavy/system folders skipped).
# Set this to narrow the scan to specific folders for a faster startup.
# MRRAWBOT_REPO_ROOTS=~/source:~/work
# MRRAWBOT_REPO_SCAN_DEPTH=6

# ---- Ollama Cloud (required for Ollama agents) ----
# Get a key at https://ollama.com  ->  Settings  ->  API keys
MRRAWBOT_OLLAMA_API_KEY=
# MRRAWBOT_OLLAMA_MODEL=qwen3-coder:480b-cloud

# ---- Claude Code (local CLI; uses your existing `claude login` subscription) ----
# MRRAWBOT_CLAUDE_BIN=/absolute/path/to/claude
# MRRAWBOT_CLAUDE_MODEL=claude-opus-4-8

# ---- Codex (local app-server; uses your existing `codex login`) ----
# MRRAWBOT_CODEX_BIN=codex
# MRRAWBOT_CODEX_HOME=
# MRRAWBOT_CODEX_MODEL=gpt-5.5

# Verbose provider logging
# MRRAWBOT_DEBUG=1
