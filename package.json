{
  "name": "mrrawbot",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "Local-only multi-agent coding assistant (Ollama Cloud + Codex + Claude Code orchestrated with LangGraph).",
  "author": "Mr Rawbot",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -k -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "app": "npm run build && electron .",
    "dist": "npm run build && electron-builder --mac",
    "electron": "electron .",
    "electron:dev": "concurrently -k -n vite,server,electron -c magenta,blue,cyan \"npm:dev:web\" \"npm:dev:server\" \"cross-env MRRAWBOT_ELECTRON_URL=http://localhost:5173 electron .\"",
    "typecheck": "tsc -b --noEmit",
    "typecheck:web": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ag-ui/client": "0.0.57",
    "@ag-ui/core": "0.0.57",
    "@anthropic-ai/claude-agent-sdk": "0.3.195",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.4",
    "@copilotkit/react-core": "1.61.2",
    "@copilotkit/react-ui": "1.61.2",
    "@copilotkit/runtime": "1.61.2",
    "@langchain/core": "1.2.1",
    "@langchain/langgraph": "1.4.7",
    "@langchain/langgraph-checkpoint-sqlite": "1.0.3",
    "@langchain/ollama": "1.3.0",
    "@octokit/rest": "^22.0.1",
    "@tanstack/react-query": "^5.62.7",
    "@uiw/react-codemirror": "^4.25.10",
    "better-sqlite3": "12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "lucide-react": "^1.22.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4.12.0",
    "rxjs": "7.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.2.0"
  },
  "overrides": {
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "42.5.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "4.3.1",
    "typescript": "^5.7.2",
    "vite": "^8.0.0",
    "vitest": "^3.2.0"
  },
  "build": {
    "appId": "com.mrrawbot.desktop",
    "productName": "Mr Rawbot",
    "asar": false,
    "npmRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "artifactName": "MrRawbot-${version}-${os}-${arch}.${ext}",
    "files": [
      "electron/**/*",
      "dist/**/*",
      "server/**/*",
      "shared/**/*",
      "tsconfig.json",
      "tsconfig.server.json",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "identity": null
    }
  }
}
