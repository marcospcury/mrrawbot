# mrrawbot is a local-only app. @copilotkit/runtime declares an OPTIONAL peer on
# @anthropic-ai/sdk@^0.57 (only used by its built-in Anthropic *adapter*, which we
# do not use — we run a fully custom in-process agent via ExperimentalEmptyAdapter).
# Meanwhile @anthropic-ai/claude-agent-sdk pulls @anthropic-ai/sdk@>=0.93. These two
# optional/independent usages can't agree on one top-level version, so we relax npm's
# strict peer resolution. Safe here because the conflicting peer is for an unused path.
legacy-peer-deps=true
